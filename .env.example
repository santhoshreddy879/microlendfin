# JWT Secret for authentication
# IMPORTANT: Change this to a cryptographically random 64+ character string in production!
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="YOUR_STRONG_JWT_SECRET_HERE"

# Server Configuration
PORT=5001
HTTPS_PORT=5443

# SSL/TLS Certificates (REQUIRED in production)
# Path to SSL key and certificate files
SSL_KEY_PATH="/path/to/ssl/private.key"
SSL_CERT_PATH="/path/to/ssl/certificate.crt"

# CORS Allowed Origins (comma-separated)
# In production, specify exact origins, e.g., "https://yourdomain.com,https://admin.yourdomain.com"
ALLOWED_ORIGINS="http://localhost:3001,http://127.0.0.1:3001"

# NODE_ENV (set to "production" in production)
NODE_ENV="development"

# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="http://localhost:3001"
